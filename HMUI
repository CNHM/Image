function DeltaXLib:Notify(Options)
    table.insert(self.NotificationQueue, {
        Title    = Options.Title or "通知",
        Content  = Options.Content or "",
        Type     = Options.Type or "info",
        Duration = Options.Duration or 4
    })
    task.spawn(ProcessNotificationQueue)
end

