            SpringTween(NotifHolder, {Size = UDim2.new(0, 320, 0, 74)}, 0.42)
            ApplyTween(ProgressFill, {Size = UDim2.new(0, 0, 1, 0)}, Duration, Enum.EasingStyle.Linear)

