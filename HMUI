                Text = Config.Title or "实时数据",
                TextColor3 = DeltaXLib.Theme.Accent,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 2
            })

            local DataContainer = Create("Frame", {
                Parent = InfoFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, IconOffX, 0, 22),
                Size = UDim2.new(1, -(IconOffX + 10), 0, 0),
                ZIndex = 2
            })
            local DataLayout = Create("UIListLayout", {
                Parent = DataContainer,
                Padding = UDim.new(0, 2),
                SortOrder = Enum.SortOrder.LayoutOrder
            })

            local Labels = {}
            local function RefreshSize()
                ApplyTween(InfoFrame, {Size = UDim2.new(1, 0, 0, 26 + DataLayout.AbsoluteContentSize.Y + 8)}, 0.2)
            end
            local function SetData(Key, Value)
                if not Labels[Key] then
                    Labels[Key] = Create("TextLabel", {
                        Parent = DataContainer,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 16),
                        Font = Enum.Font.GothamMedium,
                        Text = string.format("%s: %s", tostring(Key), tostring(Value)),
                        TextColor3 = DeltaXLib.Theme.Text,
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        RichText = true,
                        ZIndex = 3
                    })
                    RefreshSize()
                else
                    Labels[Key].Text = string.format("%s: %s", tostring(Key), tostring(Value))
                end
            end
            for k, v in pairs(InfoValues) do SetData(k, v) end

            local InfoMethods = {}
            function InfoMethods:Update(Key, NewValue)
                if Key and not NewValue then
                    for k, _ in pairs(Labels) do SetData(k, Key); break end
                else
                    SetData(Key, NewValue)
                end
            end
            return InfoMethods
        end

        return CompLib
    end

    return DeltaXLib
end

return DeltaXLib
