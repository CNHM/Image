                TextTransparency = 0.5,
                TextSize = 10,
                TextXAlignment = Enum.TextXAlignment.Right
            })

            local DataContainer = Create("Frame", {
                Parent = InfoFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 12, 0, 24),
                Size = UDim2.new(1, -24, 0, 0)
            })
            local DataLayout = Create("UIListLayout", {
                Parent = DataContainer,
                Padding = UDim.new(0, 2),
                SortOrder = Enum.SortOrder.LayoutOrder
            })

            local Labels = {}
            local function RefreshSize()
                ApplyTween(InfoFrame, {Size = UDim2.new(1, 0, 0, 28 + DataLayout.AbsoluteContentSize.Y + 6)}, 0.2)
            end

            local function SetData(Key, Value)
                if not Labels[Key] then
                    Labels[Key] = Create("TextLabel", {
                        Parent = DataContainer,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 18),
                        Font = Enum.Font.GothamMedium,
                        Text = string.format("<font color='#%02x%02x%02x'>%s</font>: %s",
                            math.floor(DeltaXLib.Theme.Accent.R * 255),
                            math.floor(DeltaXLib.Theme.Accent.G * 255),
                            math.floor(DeltaXLib.Theme.Accent.B * 255),
                            tostring(Key), tostring(Value)),
                        TextColor3 = DeltaXLib.Theme.White,
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        RichText = true
                    })
                    RefreshSize()
                else
                    Labels[Key].Text = string.format("<font color='#%02x%02x%02x'>%s</font>: %s",
                        math.floor(DeltaXLib.Theme.Accent.R * 255),
                        math.floor(DeltaXLib.Theme.Accent.G * 255),
                        math.floor(DeltaXLib.Theme.Accent.B * 255),
                        tostring(Key), tostring(Value))
                end
            end

            for k, v in pairs(InfoValues) do
                SetData(k, v)
            end

            local InfoMethods = {Instance = InfoFrame}
            function InfoMethods:Update(Key, NewValue)
                if Key and not NewValue then
                    for k, _ in pairs(Labels) do
                        SetData(k, Key)
                        break
                    end
                else
                    SetData(Key, NewValue)
                end
            end
            return InfoMethods
        end

        return CompLib
    end

    MainFrame.Size = UDim2.new(0, 0, 0, 0)
    MainFrame.Visible = true
    TweenService:Create(MainFrame, TweenInfo.new(0.48, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 620, 0, 420)}):Play()

    return DeltaXLib
end

return DeltaXLib
