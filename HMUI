                Size = UDim2.new(1, 0, 0, #Config.Options * 36)
            })
            local ListLayout = Create("UIListLayout", {Parent = List, Padding = UDim.new(0, 3)})
            Create("UIPadding", {Parent = List, PaddingLeft = UDim.new(0, 6), PaddingRight = UDim.new(0, 6)})

            local function UpdateTitle()
                if #SelectedOptions == 0 then
                    DescLabel.Text = Config.Desc or "点击展开选项列表"
                else
                    DescLabel.Text = "已选: " .. table.concat(SelectedOptions, ", ")
                end
            end

            for _, opt in pairs(Config.Options) do
                local OptBtn = Create("TextButton", {
                    Parent = List,
                    BackgroundColor3 = Color3.fromRGB(32, 32, 42),
                    Size = UDim2.new(1, 0, 0, 32),
                    Font = Enum.Font.GothamMedium,
                    Text = "  " .. tostring(opt),
                    TextColor3 = Color3.fromRGB(190, 190, 200),
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    AutoButtonColor = false
                })
                Create("UICorner", {Parent = OptBtn, CornerRadius = UDim.new(0, 10)})

                OptBtn.InputBegan:Connect(function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                        if DeltaXLib.IsDraggingSlider or DeltaXLib.IsDraggingUI then return end
                        local foundIndex = table.find(SelectedOptions, opt)
                        if foundIndex then
                            table.remove(SelectedOptions, foundIndex)
                            ApplyTween(OptBtn, {TextColor3 = Color3.fromRGB(190, 190, 200), BackgroundColor3 = Color3.fromRGB(32, 32, 42)}, 0.2)
                        else
                            table.insert(SelectedOptions, opt)
                            ApplyTween(OptBtn, {TextColor3 = DeltaXLib.Theme.Accent, BackgroundColor3 = Color3.fromRGB(0, 100, 200)}, 0.2)
                        end
                        UpdateTitle()
                        if Config.Callback then Config.Callback(SelectedOptions) end
                    end
                end)
            end

            TopBtn.InputBegan:Connect(function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
