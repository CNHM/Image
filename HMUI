local function Create(ClassName, Properties)
    local Inst = Instance.new(ClassName)
    for i, v in pairs(Properties) do
        Inst[i] = v
    end
    return Inst
end

local function GetTweenInfo(Speed, Style, Direction)
    return TweenInfo.new(Speed or DeltaXLib.Theme.TweenSpeed, Style or Enum.EasingStyle.Quart, Direction or Enum.EasingDirection.Out)
end

local function ApplyTween(Object, Properties, Speed, Style, Direction)
    local Info = GetTweenInfo(Speed, Style, Direction)
    local Tween = TweenService:Create(Object, Info, Properties)
    Tween:Play()
    return Tween
end

local function IsPlayerBusy()
    local Character = Players.LocalPlayer.Character
    local IsMoving = false
    if Character and Character:FindFirstChild("Humanoid") then
        if Character.Humanoid.MoveDirection.Magnitude > 0 then
            IsMoving = true
        end
    end
    if DeltaXLib.IsDraggingUI or DeltaXLib.IsDraggingSlider or IsMoving then
        return true
    end
    return false
end

local function MakeDraggable(Frame, DragHandle)
    local Dragging = nil
    local DragInput = nil
    local DragStart = nil
    local StartPos = nil
    DragHandle.InputBegan:Connect(function(Input, gameProcessed)
        if gameProcessed then return end
        if DeltaXLib.UILocked then return end
        if (Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch) and not DeltaXLib.IsPromptOpen then
            Dragging = true
            DeltaXLib.IsDraggingUI = true
            DragStart = Input.Position
            StartPos = Frame.Position
            Input.Changed:Connect(function()
                if Input.UserInputState == Enum.UserInputState.End then
                    Dragging = false
                    task.wait(0.08)
                    DeltaXLib.IsDraggingUI = false
                end
            end)
        end
    end)
    DragHandle.InputChanged:Connect(function(Input)
        if DeltaXLib.UILocked then return end
        if (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) and not DeltaXLib.IsPromptOpen then
            DragInput = Input
        end
    end)
    UserInputService.InputChanged:Connect(function(Input)
        if DeltaXLib.UILocked then return end
        if Input == DragInput and Dragging and not DeltaXLib.IsPromptOpen then
            local Delta = Input.Position - DragStart
            local TargetPos = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + Delta.X, StartPos.Y.Scale, StartPos.Y.Offset + Delta.Y)
            ApplyTween(Frame, {Position = TargetPos}, 0.08)
        end
    end)
end

local function Ripple(Button, ClickX, ClickY)
    if DeltaXLib.IsPromptOpen then return end
    task.spawn(function()
        local PosX = ClickX and (ClickX - Button.AbsolutePosition.X) or (Mouse.X - Button.AbsolutePosition.X)
        local PosY = ClickY and (ClickY - Button.AbsolutePosition.Y) or (Mouse.Y - Button.AbsolutePosition.Y)
        local Circle = Create("ImageLabel", {
            Parent = Button,
            BackgroundTransparency = 1,
            Image = "rbxassetid://119549561741208",
            ImageColor3 = Color3.fromRGB(255, 255, 255),
            ImageTransparency = 0.65,
            ZIndex = 10,
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0, PosX, 0, PosY)
        })
        Button.ClipsDescendants = true
        local Size = math.max(Button.AbsoluteSize.X, Button.AbsoluteSize.Y)
        ApplyTween(Circle, {
            Size = UDim2.new(0, Size * 2.8, 0, Size * 2.8),
            Position = UDim2.new(0.5, -Size * 1.4, 0.5, -Size * 1.4),
            ImageTransparency = 1
        }, 0.55)
        task.wait(0.55)
        Circle:Destroy()
    end)
end

