                TextXAlignment = Enum.TextXAlignment.Center,
                ZIndex = 3
            })

            local BarBG = Create("Frame", {
                Parent = SliderFrame,
                BackgroundColor3 = Color3.fromRGB(36, 36, 52),
                Position = UDim2.new(0, 14, 0, 42),
                Size = UDim2.new(1, -28, 0, 10)
            })
            Create("UICorner", {Parent = BarBG, CornerRadius = UDim.new(1, 0)})

            local BarFill = Create("Frame", {
                Parent = BarBG,
                BackgroundColor3 = DeltaXLib.Theme.Accent,
                Size = UDim2.new((Value - Min) / (Max - Min), 0, 1, 0),
                ZIndex = 2
            })
            Create("UICorner", {Parent = BarFill, CornerRadius = UDim.new(1, 0)})

            local SliderThumb = Create("Frame", {
                Parent = BarBG,
                BackgroundColor3 = DeltaXLib.Theme.White,
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new((Value - Min) / (Max - Min), 0, 0.5, 0),
                Size = UDim2.new(0, 16, 0, 16),
                ZIndex = 5
            })
            Create("UICorner", {Parent = SliderThumb, CornerRadius = UDim.new(1, 0)})
            Create("UIStroke", {Parent = SliderThumb, Color = DeltaXLib.Theme.Accent, Thickness = 2})

            local function UpdateSlider(Input)
                if DeltaXLib.IsPromptOpen then return end
                local Pos = math.clamp((Input.Position.X - BarBG.AbsolutePosition.X) / BarBG.AbsoluteSize.X, 0, 1)
                Value = math.floor(Min + (Max - Min) * Pos)
                ValueLabel.Text = tostring(Value)
                ApplyTween(BarFill, {Size = UDim2.new(Pos, 0, 1, 0)}, 0.08)
                ApplyTween(SliderThumb, {Position = UDim2.new(Pos, 0, 0.5, 0)}, 0.08)
                if Config.Callback then Config.Callback(Value) end
            end

            local SliderInteract = Create("TextButton", {
                Parent = SliderFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 14, 0, 36),
                Size = UDim2.new(1, -28, 0, 22),
                Text = "",
                ZIndex = 6
            })

            SliderInteract.InputBegan:Connect(function(Input)
                if (Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch) and not DeltaXLib.IsPromptOpen then
                    if DeltaXLib.IsDraggingUI or IsPlayerBusy() then return end
                    IsThisDragging = true
                    DeltaXLib.IsDraggingSlider = true
                    ApplyTween(SliderThumb, {Size = UDim2.new(0, 20, 0, 20)}, 0.15)
                    UpdateSlider(Input)
                end
            end)

            UserInputService.InputChanged:Connect(function(Input)
                if IsThisDragging and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                    UpdateSlider(Input)
                end
            end)

            UserInputService.InputEnded:Connect(function(Input)
                if (Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch) and IsThisDragging then
                    IsThisDragging = false
                    DeltaXLib.IsDraggingSlider = false
                    ApplyTween(SliderThumb, {Size = UDim2.new(0, 16, 0, 16)}, 0.15)
                end
            end)

            local SliderMethods = {}
            function SliderMethods:SetValue(NewVal)
                Value = math.clamp(NewVal, Min, Max)
                local Pos = (Value - Min) / (Max - Min)
                ValueLabel.Text = tostring(Value)
                ApplyTween(BarFill, {Size = UDim2.new(Pos, 0, 1, 0)}, 0.2)
                ApplyTween(SliderThumb, {Position = UDim2.new(Pos, 0, 0.5, 0)}, 0.2)
            end
            function SliderMethods:GetValue() return Value end
            return SliderMethods
        end

