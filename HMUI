local function Create(ClassName, Properties)
    local Instance = Instance.new(ClassName)
    for i, v in pairs(Properties) do
        Instance[i] = v
    end
    return Instance
end

local function GetTweenInfo(Speed, Style, Direction)
    return TweenInfo.new(Speed or DeltaXLib.Theme.TweenSpeed, Style or Enum.EasingStyle.Quint, Direction or Enum.EasingDirection.Out)
end

local function ApplyTween(Object, Properties, Speed, Style, Direction)
    local Info = GetTweenInfo(Speed, Style, Direction)
    local Tween = TweenService:Create(Object, Info, Properties)
    Tween:Play()
    return Tween
end

local function SpringTween(Object, Properties, Speed)
    local Info = TweenInfo.new(Speed or 0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    local Tween = TweenService:Create(Object, Info, Properties)
    Tween:Play()
    return Tween
end

local function ElasticTween(Object, Properties, Speed)
    local Info = TweenInfo.new(Speed or 0.5, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out)
    local Tween = TweenService:Create(Object, Info, Properties)
    Tween:Play()
    return Tween
end

local function IsPlayerBusy()
    local Character = Players.LocalPlayer.Character
    local IsMoving = false
    if Character and Character:FindFirstChild("Humanoid") then
        if Character.Humanoid.MoveDirection.Magnitude > 0 then
            IsMoving = true
        end
    end
    if DeltaXLib.IsDraggingUI or DeltaXLib.IsDraggingSlider or IsMoving then
        return true
    end
    return false
end

local function MakeDraggable(Frame, DragHandle)
    local Dragging = nil
    local DragInput = nil
    local DragStart = nil
    local StartPos = nil

    DragHandle.InputBegan:Connect(function(Input, gameProcessed)
        if gameProcessed then return end
        if (Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch) and not DeltaXLib.IsPromptOpen then
            Dragging = true
            DeltaXLib.IsDraggingUI = true
            DragStart = Input.Position
            StartPos = Frame.Position
            Input.Changed:Connect(function()
                if Input.UserInputState == Enum.UserInputState.End then
                    Dragging = false
                    task.wait(0.1)
                    DeltaXLib.IsDraggingUI = false
                end
            end)
        end
    end)

    DragHandle.InputChanged:Connect(function(Input)
        if (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) and not DeltaXLib.IsPromptOpen then
            DragInput = Input
        end
    end)

    UserInputService.InputChanged:Connect(function(Input)
        if Input == DragInput and Dragging and not DeltaXLib.IsPromptOpen then
            local Delta = Input.Position - DragStart
            local TargetPos = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + Delta.X, StartPos.Y.Scale, StartPos.Y.Offset + Delta.Y)
            ApplyTween(Frame, {Position = TargetPos}, 0.08)
        end
    end)
end

local function Ripple(Button)
    if DeltaXLib.IsPromptOpen then return end
    task.spawn(function()
        local mx = Mouse.X - Button.AbsolutePosition.X
        local my = Mouse.Y - Button.AbsolutePosition.Y
        local Circle = Create("ImageLabel", {
            Parent = Button,
            BackgroundTransparency = 1,
            Image = "rbxassetid://119549561741208",
            ImageColor3 = Color3.fromRGB(255, 255, 255),
            ImageTransparency = 0.55,
            ZIndex = 10,
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0, mx, 0, my)
        })
        Button.ClipsDescendants = true
        local Size = Button.AbsoluteSize.X > Button.AbsoluteSize.Y and Button.AbsoluteSize.X or Button.AbsoluteSize.Y
        local T = ApplyTween(Circle, {
            Size = UDim2.new(0, Size * 2.8, 0, Size * 2.8),
            Position = UDim2.new(0.5, -Size * 1.4, 0.5, -Size * 1.4),
            ImageTransparency = 1
        }, 0.65, Enum.EasingStyle.Quint)
        task.wait(0.65)
        Circle:Destroy()
    end)
end

local function AddIcon(Parent, IconId, Size, XOff, YOff)
    if not IconId or IconId == "" then return nil end
    local sz = Size or 18
    local Img = Create("ImageLabel", {
        Parent = Parent,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, XOff or 14, 0.5, -(sz / 2) + (YOff or 0)),
        Size = UDim2.new(0, sz, 0, sz),
        Image = IconId,
        ImageColor3 = DeltaXLib.Theme.Accent,
        ScaleType = Enum.ScaleType.Fit,
        ZIndex = (Parent.ZIndex or 1) + 1
    })
    return Img
end

local function PulseGlow(Frame, Color)
    task.spawn(function()
        local Stroke = Create("UIStroke", {
            Parent = Frame,
            Color = Color or DeltaXLib.Theme.Accent,
            Thickness = 2,
            Transparency = 0.2,
            ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        })
        ApplyTween(Stroke, {Transparency = 1}, 0.5)
        task.wait(0.5)
        Stroke:Destroy()
    end)
end

