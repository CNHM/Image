        function CompLib:Info(Config)
            local InfoValues = Config.Values or {}
            local InfoFrame = Create("Frame", {
                Parent = Config.Parent or TabPage,
                BackgroundColor3 = DeltaXLib.Theme.CardBg,
                Size = UDim2.new(1, 0, 0, 48),
                Name = (Config.Title or "Info") .. "_Info",
                ClipsDescendants = true
            })
            Create("UICorner", {Parent = InfoFrame, CornerRadius = DeltaXLib.Theme.Rounded})
            local InfoStroke = Create("UIStroke", {
                Parent = InfoFrame,
                Color = DeltaXLib.Theme.Accent,
                Thickness = 1.5,
                Transparency = 0.55
            })

            local HeaderBar = Create("Frame", {
                Parent = InfoFrame,
                BackgroundColor3 = DeltaXLib.Theme.AccentDark,
                BackgroundTransparency = 0.85,
                Position = UDim2.new(0, 0, 0, 0),
                Size = UDim2.new(0, 3, 0, 0)
            })
            Create("UICorner", {Parent = HeaderBar, CornerRadius = UDim.new(0, 2)})

            local InfoIconBg = Create("Frame", {
                Parent = InfoFrame,
                BackgroundColor3 = DeltaXLib.Theme.AccentDark,
                BackgroundTransparency = 0.7,
                Position = UDim2.new(0, 10, 0, 8),
                Size = UDim2.new(0, 22, 0, 22)
            })
            Create("UICorner", {Parent = InfoIconBg, CornerRadius = UDim.new(0, 6)})
            Create("ImageLabel", {
                Parent = InfoIconBg,
                BackgroundTransparency = 1,
                Position = UDim2.new(0.1, 0, 0.1, 0),
                Size = UDim2.new(0.8, 0, 0.8, 0),
                Image = Config.Icon or "rbxassetid://6026568198",
                ImageColor3 = DeltaXLib.Theme.Accent,
                ScaleType = Enum.ScaleType.Fit
            })

            local TitleLabel2 = Create("TextLabel", {
                Name = "TitleLabel",
                Parent = InfoFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 40, 0, 6),
                Size = UDim2.new(1, -50, 0, 14),
                Font = Enum.Font.GothamBold,
                Text = Config.Title or "实时数据",
                TextColor3 = DeltaXLib.Theme.Accent,
                TextSize = 11,
                TextXAlignment = Enum.TextXAlignment.Left
            })

            local DataContainer = Create("Frame", {
                Parent = InfoFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 12, 0, 24),
                Size = UDim2.new(1, -24, 0, 0)
            })
            local DataLayout = Create("UIListLayout", {
                Parent = DataContainer,
                Padding = UDim.new(0, 2),
                SortOrder = Enum.SortOrder.LayoutOrder
            })

            local Labels = {}
            local function RefreshSize()
                local ContentSize = DataLayout.AbsoluteContentSize.Y
                local newH = 32 + ContentSize + 6
                ApplyTween(InfoFrame, {Size = UDim2.new(1, 0, 0, newH)}, 0.2)
                ApplyTween(HeaderBar, {Size = UDim2.new(0, 3, 0, newH)}, 0.2)
            end

            local function SetData(Key, Value)
                if not Labels[Key] then
                    Labels[Key] = Create("TextLabel", {
                        Parent = DataContainer,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 18),
                        Font = Enum.Font.GothamMedium,
                        Text = string.format("<b>%s</b>: %s", tostring(Key), tostring(Value)),
                        TextColor3 = DeltaXLib.Theme.White,
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        RichText = true
                    })
                    RefreshSize()
                else
                    Labels[Key].Text = string.format("<b>%s</b>: %s", tostring(Key), tostring(Value))
                end
            end

            for k, v in pairs(InfoValues) do
                SetData(k, v)
            end

            local InfoMethods = {}
            function InfoMethods:Update(Key, NewValue)
                if Key and not NewValue then
                    for k, _ in pairs(Labels) do
                        SetData(k, Key)
                        break
                    end
                else
                    SetData(Key, NewValue)
                end
            end

            local InfoPulseRunning = true
            task.spawn(function()
                while InfoPulseRunning and InfoFrame.Parent do
                    ApplyTween(InfoStroke, {Transparency = 0.3}, 1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                    task.wait(1.2)
                    ApplyTween(InfoStroke, {Transparency = 0.7}, 1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                    task.wait(1.2)
                end
            end)

            InfoFrame.AncestryChanged:Connect(function()
                if not InfoFrame.Parent then
                    InfoPulseRunning = false
                end
            end)

            return InfoMethods
        end

        return CompLib
    end

    MainFrame.Size = UDim2.new(0, 0, 0, 0)
    MainFrame.Visible = true
    task.delay(0.05, function()
        SpringTween(MainFrame, {Size = UDim2.new(0, 620, 0, 420)}, 0.55)
    end)

    return DeltaXLib
end

return DeltaXLib
