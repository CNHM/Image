    SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
        DeltaXLib.SearchQuery = string.lower(SearchBox.Text)
        local AllTabs = {}
        for _, v in pairs(ContentHolder:GetChildren()) do
            if v:IsA("ScrollingFrame") then table.insert(AllTabs, v) end
        end
        table.sort(AllTabs, function(a, b) return a.Name < b.Name end)
        local FirstTab = AllTabs[1]
        if not FirstTab then return end

        if DeltaXLib.SearchQuery ~= "" then
            for i, TabPage in ipairs(AllTabs) do
                TabPage.Visible = (i == 1)
                for _, Component in pairs(TabPage:GetChildren()) do
                    if Component.Name:find("_Section") then
                        local Container = Component:FindFirstChild("Container")
                        if Container then
                            for _, SubItem in pairs(Container:GetChildren()) do
                                if SubItem:IsA("Frame") and SubItem:FindFirstChild("TitleLabel") then
                                    local SubTitle = string.lower(SubItem.TitleLabel.Text)
                                    if string.find(SubTitle, DeltaXLib.SearchQuery) then
                                        SubItem.Visible = true
                                        SubItem.Parent = FirstTab
                                        if not SubItem:FindFirstChild("OldSection") then
                                            local Tag = Instance.new("StringValue", SubItem)
                                            Tag.Name = "OldSection"
                                            Tag.Value = Component.Name
                                        end
                                    else
                                        SubItem.Visible = false
                                    end
                                end
                            end
                        end
                        Component.Visible = false
                    elseif Component:IsA("Frame") and Component:FindFirstChild("TitleLabel") then
                        local Title = string.lower(Component.TitleLabel.Text)
                        if string.find(Title, DeltaXLib.SearchQuery) then
                            Component.Visible = true
                            if TabPage ~= FirstTab then
                                Component.Parent = FirstTab
                                if not Component:FindFirstChild("OldTab") then
                                    local Tag = Instance.new("StringValue", Component)
                                    Tag.Name = "OldTab"
                                    Tag.Value = TabPage.Name
                                end
                            end
                        else
                            Component.Visible = false
                        end
                    end
                end
            end
        else
            for _, Item in pairs(FirstTab:GetChildren()) do
                local OS = Item:FindFirstChild("OldSection")
                local OT = Item:FindFirstChild("OldTab")
                if OS then
                    local Sect = FirstTab:FindFirstChild(OS.Value) or ContentHolder:FindFirstChild(OS.Value, true)
                    if Sect and Sect:FindFirstChild("Container") then Item.Parent = Sect.Container end
                    OS:Destroy()
                elseif OT then
                    local Target = ContentHolder:FindFirstChild(OT.Value)
                    if Target then Item.Parent = Target end
                    OT:Destroy()
                end
            end
            for _, TabPage in ipairs(AllTabs) do
                TabPage.Visible = (TabPage == DeltaXLib.CurrentTab)
                for _, Comp in pairs(TabPage:GetChildren()) do
                    Comp.Visible = true
                    if Comp.Name:find("_Section") then
                        local Con = Comp:FindFirstChild("Container")
                        if Con then for _, s in pairs(Con:GetChildren()) do s.Visible = true end end
                    end
                end
            end
        end
        task.wait()
        FirstTab.CanvasSize = UDim2.new(0, 0, 0, FirstTab.UIListLayout.AbsoluteContentSize.Y + 20)
    end)

