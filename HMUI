        function CompLib:Dropdown(Config)
            local SelectedOptions = {}
            local Expanded = false
            local hasIcon = Config.Icon and Config.Icon ~= ""
            local DropFrame = Create("Frame", {
                Parent = Config.Parent or TabPage,
                Size = UDim2.new(1, 0, 0, 52),
                ClipsDescendants = true,
                BackgroundColor3 = DeltaXLib.Theme.CardBg,
                Name = Config.Title .. "_Drop"
            })
            Create("UICorner", {Parent = DropFrame, CornerRadius = DeltaXLib.Theme.Rounded})
            local DropStroke = Create("UIStroke", {
                Parent = DropFrame,
                Color = DeltaXLib.Theme.Accent,
                Thickness = 1,
                Transparency = 1
            })

            local TopBtn = Create("TextButton", {
                Parent = DropFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 52),
                Text = ""
            })

            if hasIcon then
                local IconBg = Create("Frame", {
                    Parent = TopBtn,
                    BackgroundColor3 = DeltaXLib.Theme.AccentDark,
                    BackgroundTransparency = 0.7,
                    Position = UDim2.new(0, 12, 0.5, -13),
                    Size = UDim2.new(0, 26, 0, 26)
                })
                Create("UICorner", {Parent = IconBg, CornerRadius = UDim.new(0, 8)})
                Create("ImageLabel", {
                    Parent = IconBg,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0.1, 0, 0.1, 0),
                    Size = UDim2.new(0.8, 0, 0.8, 0),
                    Image = Config.Icon,
                    ImageColor3 = DeltaXLib.Theme.Accent,
                    ScaleType = Enum.ScaleType.Fit
                })
            end

            local xOff = hasIcon and 50 or 15
            local TitleLabel = Create("TextLabel", {
                Name = "TitleLabel",
                Parent = TopBtn,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, xOff, 0, 0),
                Size = UDim2.new(1, -(xOff + 44), 1, 0),
                Font = Enum.Font.GothamBold,
                Text = Config.Title .. " : " .. (Config.AllowNone and "未选择" or "请选择"),
                TextColor3 = DeltaXLib.Theme.White,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left
            })

            local ChevronBg = Create("Frame", {
                Parent = TopBtn,
                BackgroundColor3 = DeltaXLib.Theme.AccentDark,
                BackgroundTransparency = 0.8,
                Position = UDim2.new(1, -36, 0.5, -11),
                Size = UDim2.new(0, 22, 0, 22)
            })
            Create("UICorner", {Parent = ChevronBg, CornerRadius = UDim.new(1, 0)})

            local Chevron = Create("ImageLabel", {
                Parent = ChevronBg,
                BackgroundTransparency = 1,
                Position = UDim2.new(0.1, 0, 0.1, 0),
                Size = UDim2.new(0.8, 0, 0.8, 0),
                Image = "rbxassetid://6034829095",
                ImageColor3 = DeltaXLib.Theme.Accent,
                Rotation = 0,
                ScaleType = Enum.ScaleType.Fit
            })

            local Divider = Create("Frame", {
                Parent = DropFrame,
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BackgroundTransparency = 0.9,
                Position = UDim2.new(0, 12, 0, 52),
                Size = UDim2.new(1, -24, 0, 1)
            })

            local List = Create("Frame", {
                Parent = DropFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 6, 0, 56),
                Size = UDim2.new(1, -12, 0, #Config.Options * 36)
            })
            local ListLayout = Create("UIListLayout", {Parent = List, Padding = UDim.new(0, 3)})

            local function UpdateTitle()
                if #SelectedOptions == 0 then
                    TitleLabel.Text = Config.Title .. " : " .. (Config.AllowNone and "未选择" or "请选择")
                else
                    TitleLabel.Text = Config.Title .. " : " .. table.concat(SelectedOptions, ", ")
                end
            end

            for _, opt in pairs(Config.Options) do
                local OptBtn = Create("TextButton", {
                    Parent = List,
                    BackgroundColor3 = Color3.fromRGB(32, 32, 42),
                    Size = UDim2.new(1, 0, 0, 34),
                    Font = Enum.Font.GothamMedium,
                    Text = "",
                    TextColor3 = Color3.fromRGB(190, 195, 210),
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    AutoButtonColor = false
                })
                Create("UICorner", {Parent = OptBtn, CornerRadius = UDim.new(0, 10)})

                local OptCheck = Create("Frame", {
                    Parent = OptBtn,
                    BackgroundColor3 = DeltaXLib.Theme.AccentDark,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 8, 0.5, -8),
                    Size = UDim2.new(0, 16, 0, 16)
                })
                Create("UICorner", {Parent = OptCheck, CornerRadius = UDim.new(1, 0)})

                local OptText = Create("TextLabel", {
                    Parent = OptBtn,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 30, 0, 0),
                    Size = UDim2.new(1, -36, 1, 0),
                    Font = Enum.Font.GothamMedium,
                    Text = tostring(opt),
                    TextColor3 = Color3.fromRGB(190, 195, 210),
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left
                })

                OptBtn.MouseEnter:Connect(function()
                    if not table.find(SelectedOptions, opt) then
                        ApplyTween(OptBtn, {BackgroundColor3 = Color3.fromRGB(40, 40, 52)}, 0.15)
                    end
                end)
                OptBtn.MouseLeave:Connect(function()
                    if not table.find(SelectedOptions, opt) then
                        ApplyTween(OptBtn, {BackgroundColor3 = Color3.fromRGB(32, 32, 42)}, 0.15)
                    end
                end)

                OptBtn.InputBegan:Connect(function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                        if DeltaXLib.IsDraggingSlider then return end
                        local foundIndex = table.find(SelectedOptions, opt)
                        if foundIndex then
                            table.remove(SelectedOptions, foundIndex)
                            ApplyTween(OptBtn, {BackgroundColor3 = Color3.fromRGB(32, 32, 42)}, 0.2)
                            ApplyTween(OptText, {TextColor3 = Color3.fromRGB(190, 195, 210)}, 0.2)
                            ApplyTween(OptCheck, {BackgroundTransparency = 1}, 0.2)
                        else
                            table.insert(SelectedOptions, opt)
                            ApplyTween(OptBtn, {BackgroundColor3 = Color3.fromRGB(36, 52, 80)}, 0.2)
                            ApplyTween(OptText, {TextColor3 = DeltaXLib.Theme.Accent}, 0.2)
                            ApplyTween(OptCheck, {BackgroundTransparency = 0.2}, 0.2)
                        end
                        UpdateTitle()
                        if Config.Callback then Config.Callback(SelectedOptions) end
                    end
                end)
            end

            TopBtn.MouseEnter:Connect(function()
                ApplyTween(DropFrame, {BackgroundColor3 = DeltaXLib.Theme.CardHover}, 0.15)
                ApplyTween(DropStroke, {Transparency = 0.7}, 0.15)
            end)
            TopBtn.MouseLeave:Connect(function()
                ApplyTween(DropFrame, {BackgroundColor3 = DeltaXLib.Theme.CardBg}, 0.2)
                ApplyTween(DropStroke, {Transparency = 1}, 0.2)
            end)

            TopBtn.InputBegan:Connect(function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                    if DeltaXLib.IsDraggingSlider then return end
                    Expanded = not Expanded
                    local optHeight = ListLayout.AbsoluteContentSize.Y
                    local targetHeight = Expanded and (56 + optHeight + 8) or 52
                    ApplyTween(DropFrame, {Size = UDim2.new(1, 0, 0, targetHeight)}, 0.32, Enum.EasingStyle.Quint)
                    ApplyTween(Chevron, {Rotation = Expanded and 180 or 0}, 0.3, Enum.EasingStyle.Quint)
                    ApplyTween(Divider, {BackgroundTransparency = Expanded and 0.8 or 1}, 0.3)
                end
            end)

            local DropMethods = {Instance = DropFrame}
            function DropMethods:GetSelected() return SelectedOptions end

            return DropMethods
        end

