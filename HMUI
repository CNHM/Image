                Create("ImageLabel", {
                    Parent = IconBg,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0.1, 0, 0.1, 0),
                    Size = UDim2.new(0.8, 0, 0.8, 0),
                    Image = Config.Icon,
                    ImageColor3 = DeltaXLib.Theme.Accent,
                    ScaleType = Enum.ScaleType.Fit
                })
            end

            local xOff = hasIcon and 46 or 14
            local TitleLabel = Create("TextLabel", {
                Name = "TitleLabel",
                Parent = Header,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, xOff, 0, 0),
                Size = UDim2.new(1, -(xOff + 44), 1, 0),
                Font = Enum.Font.GothamBold,
                Text = Config.Title,
                TextColor3 = DeltaXLib.Theme.Accent,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left
            })

            local ArrowBg = Create("Frame", {
                Parent = Header,
                BackgroundColor3 = DeltaXLib.Theme.AccentDark,
                BackgroundTransparency = 0.8,
                Position = UDim2.new(1, -36, 0.5, -11),
                Size = UDim2.new(0, 22, 0, 22)
            })
            Create("UICorner", {Parent = ArrowBg, CornerRadius = UDim.new(1, 0)})

            local Arrow = Create("ImageLabel", {
                Parent = ArrowBg,
                BackgroundTransparency = 1,
                Position = UDim2.new(0.1, 0, 0.1, 0),
                Size = UDim2.new(0.8, 0, 0.8, 0),
                Image = "rbxassetid://6034829095",
                ImageColor3 = DeltaXLib.Theme.Accent,
                Rotation = Expanded and 180 or 0,
                ScaleType = Enum.ScaleType.Fit
            })

            local Container = Create("Frame", {
                Parent = SectionFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 5, 0, 38),
                Size = UDim2.new(1, -10, 0, 0),
                Name = "Container"
            })
            local Layout = Create("UIListLayout", {
                Parent = Container,
                Padding = UDim.new(0, 6),
                SortOrder = Enum.SortOrder.LayoutOrder
            })
            Create("UIPadding", {Parent = Container, PaddingBottom = UDim.new(0, 6)})

            Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                if Expanded then
                    ApplyTween(SectionFrame, {Size = UDim2.new(1, 0, 0, Layout.AbsoluteContentSize.Y + 52)}, 0.25, Enum.EasingStyle.Quint)
                end
            end)

            local function ToggleSection()
                if IsPlayerBusy() then return end
                if DeltaXLib.IsPromptOpen then return end
                Expanded = not Expanded
                local TargetHeight = Expanded and (Layout.AbsoluteContentSize.Y + 56) or 42
                ApplyTween(SectionFrame, {Size = UDim2.new(1, 0, 0, TargetHeight)}, 0.38, Enum.EasingStyle.Quint)
                ApplyTween(Arrow, {Rotation = Expanded and 180 or 0}, 0.35, Enum.EasingStyle.Quint)
                ApplyTween(SecStroke, {Transparency = Expanded and 0.45 or 0.75}, 0.3)
                task.wait(0.38)
                TabPage.CanvasSize = UDim2.new(0, 0, 0, TabPage.UIListLayout.AbsoluteContentSize.Y + 20)
            end

            Header.InputBegan:Connect(function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                    if DeltaXLib.IsDraggingSlider or DeltaXLib.IsDraggingUI or IsPlayerBusy() then return end
                    ToggleSection()
                    Ripple(Header)
                end
            end)

            Header.MouseEnter:Connect(function()
                ApplyTween(SectionFrame, {BackgroundColor3 = Color3.fromRGB(26, 26, 34)}, 0.15)
            end)
            Header.MouseLeave:Connect(function()
                ApplyTween(SectionFrame, {BackgroundColor3 = Color3.fromRGB(20, 20, 26)}, 0.2)
            end)

            local SectionItems = {}
            local function AddToSection(MethodName, ComponentConfig)
                ComponentConfig.Parent = Container
                return CompLib[MethodName](CompLib, ComponentConfig)
            end
            function SectionItems:Button(Conf) return AddToSection("Button", Conf) end
            function SectionItems:Toggle(Conf) return AddToSection("Toggle", Conf) end
            function SectionItems:Slider(Conf) return AddToSection("Slider", Conf) end
            function SectionItems:Dropdown(Conf) return AddToSection("Dropdown", Conf) end
            function SectionItems:Info(Conf) return AddToSection("Info", Conf) end
            function SectionItems:Label(Conf) return AddToSection("Label", Conf) end
            function SectionItems:Input(Conf) return AddToSection("Input", Conf) end
            return SectionItems
        end

