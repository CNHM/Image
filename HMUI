        local function ActivateTab()
            for _, v in pairs(ContentHolder:GetChildren()) do
                if v:IsA("ScrollingFrame") then v.Visible = false end
            end
            for _, v in pairs(TabContainer:GetChildren()) do
                if v:IsA("Frame") then
                    ApplyTween(v, {BackgroundColor3 = Color3.fromRGB(22, 22, 30)}, 0.2)
                    local nlbl = v:FindFirstChildOfClass("TextLabel")
                    if nlbl then ApplyTween(nlbl, {TextColor3 = DeltaXLib.Theme.TextDark}, 0.2) end
                    for _, child in pairs(v:GetChildren()) do
                        if child:IsA("Frame") and child.Size == UDim2.new(0, 3, 0.64, 0) then
                            child.Visible = false
                        end
                        if child:IsA("Frame") and child.Size == UDim2.new(0, 24, 0, 24) then
                            ApplyTween(child, {BackgroundColor3 = Color3.fromRGB(35, 35, 50)}, 0.2)
                            local ic = child:FindFirstChildOfClass("ImageLabel")
                            if ic then ApplyTween(ic, {ImageColor3 = DeltaXLib.Theme.TextDark}, 0.2) end
                        end
                    end
                end
            end
            TabPage.Visible = true
            DeltaXLib.CurrentTab = TabPage
            ApplyTween(TabBtn, {BackgroundColor3 = Color3.fromRGB(30, 30, 46)}, 0.2)
            ApplyTween(TabNameLbl, {TextColor3 = DeltaXLib.Theme.White}, 0.2)
