                if enter then pcall(TBCallback, TBBox.Text) end
            end)
            TBBox:GetPropertyChangedSignal("Text"):Connect(function()
                pcall(TBLiveCallback, TBBox.Text)
            end)
            local TBObj = {}
            function TBObj:Get() return TBBox.Text end
            function TBObj:Set(t) TBBox.Text = t end
            function TBObj:SetTitle(t) TBTitleLbl.Text = t end
            return TBObj
        end
