        function Tab:ColorPicker(cpCfg)
            cpCfg = cpCfg or {}
            local CPTitle = cpCfg.Title or "颜色选择器"
            local CPDefault = cpCfg.Default or Color3.fromRGB(99, 102, 241)
            local CPCallback = cpCfg.Callback or function() end
            local cpH, cpS, cpV = Color3.toHSV(CPDefault)
            local cpColor = CPDefault
            local cpOpen = false
            local CPFrame = CreateRoundFrame(TabContent, UDim2.new(1, 0, 0, 44), UDim2.new(0, 0, 0, 0), Theme.TertiaryBackground, UDim.new(0, 12))
            CPFrame.ZIndex = 5
            CPFrame.ClipsDescendants = false
            MakeStroke(CPFrame, Theme.Border, 1)
            local CPDetect = CreateButton(CPFrame, UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), nil, 7)
            local CPTitleLbl = CreateLabel(CPFrame, CPTitle, UDim2.new(1, -70, 1, 0), UDim2.new(0, 10, 0, 0), Theme.TextPrimary, Enum.Font.GothamBold, 14, Enum.TextXAlignment.Left, 6)
            local CPPreview = CreateRoundFrame(CPFrame, UDim2.new(0, 40, 0, 24), UDim2.new(1, -48, 0.5, -12), CPDefault, UDim.new(0, 8))
            CPPreview.ZIndex = 6
            MakeStroke(CPPreview, Theme.Border, 1.5)
            local CPPanel = CreateRoundFrame(CPFrame, UDim2.new(1, 0, 0, 0), UDim2.new(0, 0, 1, 8), Theme.ColorPickerBackground, UDim.new(0, 14))
            CPPanel.ZIndex = 15
            CPPanel.ClipsDescendants = true
            MakeStroke(CPPanel, Theme.Accent, 1)
            local CPSVBoard = CreateRoundFrame(CPPanel, UDim2.new(1, -18, 0, 110), UDim2.new(0, 9, 0, 9), Color3.fromHSV(cpH, 1, 1), UDim.new(0, 10))
            CPSVBoard.ZIndex = 16
            local CPSVWhite = Instance.new("UIGradient")
            CPSVWhite.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))})
            CPSVWhite.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1)})
            CPSVWhite.Parent = CPSVBoard
            local CPSVBlack = CreateRoundFrame(CPSVBoard, UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), Color3.fromRGB(0, 0, 0), UDim.new(0, 10))
            CPSVBlack.ZIndex = 17
            local CPSVBlackGrad = Instance.new("UIGradient")
            CPSVBlackGrad.Rotation = 90
            CPSVBlackGrad.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0)})
            CPSVBlackGrad.Parent = CPSVBlack
            local CPSVKnob = CreateRoundFrame(CPSVBoard, UDim2.new(0, 14, 0, 14), UDim2.new(cpS, -7, 1 - cpV, -7), Color3.fromRGB(255, 255, 255), UDim.new(1, 0))
            CPSVKnob.ZIndex = 19
            MakeStroke(CPSVKnob, Color3.fromRGB(0, 0, 0), 2)
            local CPHueBar = CreateRoundFrame(CPPanel, UDim2.new(1, -18, 0, 16), UDim2.new(0, 9, 0, 126), Color3.fromRGB(255, 255, 255), UDim.new(1, 0))
            CPHueBar.ZIndex = 16
            local CPHueGrad = Instance.new("UIGradient")
            CPHueGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromHSV(0, 1, 1)),
                ColorSequenceKeypoint.new(1/6, Color3.fromHSV(1/6, 1, 1)),
                ColorSequenceKeypoint.new(2/6, Color3.fromHSV(2/6, 1, 1)),
                ColorSequenceKeypoint.new(3/6, Color3.fromHSV(3/6, 1, 1)),
                ColorSequenceKeypoint.new(4/6, Color3.fromHSV(4/6, 1, 1)),
                ColorSequenceKeypoint.new(5/6, Color3.fromHSV(5/6, 1, 1)),
                ColorSequenceKeypoint.new(1, Color3.fromHSV(1, 1, 1)),
            })
            CPHueGrad.Parent = CPHueBar
            local CPHueKnob = CreateRoundFrame(CPHueBar, UDim2.new(0, 12, 1, 6), UDim2.new(cpH, -6, 0.5, -11), Color3.fromRGB(255, 255, 255), UDim.new(0, 5))
            CPHueKnob.ZIndex = 18
            MakeStroke(CPHueKnob, Color3.fromRGB(0, 0, 0), 2)
            local CPHexRow = CreateFrame(CPPanel, UDim2.new(1, -18, 0, 20), UDim2.new(0, 9, 0, 150), nil, 16)
            CPHexRow.BackgroundTransparency = 1
            local CPHexLabel = CreateLabel(CPHexRow, "颜色代码: #" .. CPDefault:ToHex():upper(), UDim2.new(0.6, 0, 1, 0), UDim2.new(0, 0, 0, 0), Theme.TextSecondary, Enum.Font.Gotham, 12, Enum.TextXAlignment.Left, 17)
            local CPPreviewSmall = CreateRoundFrame(CPHexRow, UDim2.new(0, 40, 0, 18), UDim2.new(1, -44, 0.5, -9), CPDefault, UDim.new(0, 6))
            CPPreviewSmall.ZIndex = 17
            local function RefreshCP()
                cpColor = Color3.fromHSV(cpH, cpS, cpV)
                Tween(CPPreview, {BackgroundColor3 = cpColor}, TweenFast)
                Tween(CPPreviewSmall, {BackgroundColor3 = cpColor}, TweenFast)
                Tween(CPSVBoard, {BackgroundColor3 = Color3.fromHSV(cpH, 1, 1)}, TweenFast)
                CPHexLabel.Text = "颜色代码: #" .. cpColor:ToHex():upper()
                pcall(CPCallback, cpColor)
            end
            local svDrag = false
            local hueDrag = false
            local CPSVDetect = CreateButton(CPSVBoard, UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), nil, 20)
            CPSVDetect.MouseButton1Down:Connect(function()
                svDrag = true
                local ap = CPSVBoard.AbsolutePosition
                local as = CPSVBoard.AbsoluteSize
                cpS = math.clamp((Mouse.X - ap.X) / as.X, 0, 1)
                cpV = 1 - math.clamp((Mouse.Y - ap.Y) / as.Y, 0, 1)
                Tween(CPSVKnob, {Position = UDim2.new(cpS, -7, 1 - cpV, -7)}, TweenFast)
                RefreshCP()
            end)
            local CPHueDetect = CreateButton(CPHueBar, UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), nil, 20)
            CPHueDetect.MouseButton1Down:Connect(function()
                hueDrag = true
                local ap = CPHueBar.AbsolutePosition
                local as = CPHueBar.AbsoluteSize
                cpH = math.clamp((Mouse.X - ap.X) / as.X, 0, 1)
                Tween(CPHueKnob, {Position = UDim2.new(cpH, -6, 0.5, -11)}, TweenFast)
                RefreshCP()
            end)
            UserInputService.InputChanged:Connect(function(inp)
                if inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
                if svDrag then
                    local ap = CPSVBoard.AbsolutePosition
                    local as = CPSVBoard.AbsoluteSize
                    cpS = math.clamp((inp.Position.X - ap.X) / as.X, 0, 1)
                    cpV = 1 - math.clamp((inp.Position.Y - ap.Y) / as.Y, 0, 1)
                    Tween(CPSVKnob, {Position = UDim2.new(cpS, -7, 1 - cpV, -7)}, TweenFast)
                    RefreshCP()
                end
                if hueDrag then
                    local ap = CPHueBar.AbsolutePosition
                    local as = CPHueBar.AbsoluteSize
                    cpH = math.clamp((inp.Position.X - ap.X) / as.X, 0, 1)
                    Tween(CPHueKnob, {Position = UDim2.new(cpH, -6, 0.5, -11)}, TweenFast)
                    RefreshCP()
                end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    svDrag = false
                    hueDrag = false
                end
            end)
            CPDetect.MouseButton1Click:Connect(function()
                cpOpen = not cpOpen
                if cpOpen then
                    Tween(CPPanel, {Size = UDim2.new(1, 0, 0, 180)}, TweenSpring)
                    Tween(CPFrame, {BackgroundColor3 = Theme.QuaternaryBackground}, TweenFast)
                else
                    Tween(CPPanel, {Size = UDim2.new(1, 0, 0, 0)}, TweenFast)
                    Tween(CPFrame, {BackgroundColor3 = Theme.TertiaryBackground}, TweenFast)
                end
            end)
            local CPObj = {}
            function CPObj:Get() return cpColor end
            function CPObj:Set(c)
                cpColor = c
                cpH, cpS, cpV = Color3.toHSV(c)
                Tween(CPPreview, {BackgroundColor3 = c}, TweenFast)
                Tween(CPPreviewSmall, {BackgroundColor3 = c}, TweenFast)
                Tween(CPSVBoard, {BackgroundColor3 = Color3.fromHSV(cpH, 1, 1)}, TweenFast)
                Tween(CPSVKnob, {Position = UDim2.new(cpS, -7, 1 - cpV, -7)}, TweenFast)
                Tween(CPHueKnob, {Position = UDim2.new(cpH, -6, 0.5, -11)}, TweenFast)
                CPHexLabel.Text = "颜色代码: #" .. c:ToHex():upper()
            end
            return CPObj
        end
        function Tab:Keybind(kbCfg)
            kbCfg = kbCfg or {}
            local KBTitle = kbCfg.Title or "快捷键绑定"
            local KBDesc = kbCfg.Desc or ""
            local KBDefault = kbCfg.Default or Enum.KeyCode.RightShift
            local KBCallback = kbCfg.Callback or function() end
            local KBPassthrough = kbCfg.Passthrough or false
            local kbKey = KBDefault
            local kbListening = false
            local hasDesc = KBDesc ~= ""
            local kbH = hasDesc and 56 or 40
            local KBFrame = CreateRoundFrame(TabContent, UDim2.new(1, 0, 0, kbH), UDim2.new(0, 0, 0, 0), Theme.TertiaryBackground, UDim.new(0, 12))
            KBFrame.ZIndex = 3
            MakeStroke(KBFrame, Theme.Border, 1)
            local KBTitleLbl = CreateLabel(KBFrame, KBTitle, UDim2.new(1, -112, 0, 20), UDim2.new(0, 10, hasDesc and 0 or 0.5, hasDesc and 9 or -10), Theme.TextPrimary, Enum.Font.GothamBold, 14, Enum.TextXAlignment.Left, 4)
            if hasDesc then
                local KBDescLbl = CreateLabel(KBFrame, KBDesc, UDim2.new(1, -112, 0, 14), UDim2.new(0, 10, 0, 30), Theme.TextSecondary, Enum.Font.Gotham, 11, Enum.TextXAlignment.Left, 4)
            end
            local KBBtnFrame = CreateRoundFrame(KBFrame, UDim2.new(0, 96, 0, 28), UDim2.new(1, -104, 0.5, -14), Theme.KeybindBackground, UDim.new(0, 9))
            KBBtnFrame.ZIndex = 4
            MakeStroke(KBBtnFrame, Theme.Border, 1)
            local KBKeyLbl = CreateLabel(KBBtnFrame, kbKey.Name, UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), Theme.Accent, Enum.Font.GothamBold, 13, Enum.TextXAlignment.Center, 5)
            local KBDetect = CreateButton(KBBtnFrame, UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), nil, 6)
            KBDetect.MouseButton1Click:Connect(function()
                if kbListening then return end
                kbListening = true
                KBKeyLbl.Text = "按下按键..."
                Tween(KBBtnFrame, {BackgroundColor3 = Theme.AccentDark}, TweenFast)
                local conn
                conn = UserInputService.InputBegan:Connect(function(inp, gpe)
                    if gpe then return end
                    if inp.UserInputType == Enum.UserInputType.Keyboard then
                        kbKey = inp.KeyCode
                        KBKeyLbl.Text = kbKey.Name
                        kbListening = false
                        Tween(KBBtnFrame, {BackgroundColor3 = Theme.KeybindBackground}, TweenFast)
                        conn:Disconnect()
                    end
                end)
            end)
            KBDetect.MouseEnter:Connect(function()
                if not kbListening then Tween(KBBtnFrame, {BackgroundColor3 = Theme.TertiaryBackground}, TweenFast) end
            end)
            KBDetect.MouseLeave:Connect(function()
                if not kbListening then Tween(KBBtnFrame, {BackgroundColor3 = Theme.KeybindBackground}, TweenFast) end
            end)
            UserInputService.InputBegan:Connect(function(inp, gpe)
                if gpe and not KBPassthrough then return end
                if not kbListening and inp.KeyCode == kbKey then
                    pcall(KBCallback, kbKey)
                end
            end)
            local KBObj = {}
            function KBObj:Get() return kbKey end
            function KBObj:Set(k) kbKey = k KBKeyLbl.Text = k.Name end
            function KBObj:SetTitle(t) KBTitleLbl.Text = t end
            return KBObj
        end
