local function FireNotification(title, body, notifKind, holdTime)
    holdTime = holdTime or 4.5
    notifKind = notifKind or "信息"
    local barColor = Theme.Accent
    if notifKind == "成功" then barColor = Theme.Success
    elseif notifKind == "警告" then barColor = Theme.Warning
    elseif notifKind == "错误" then barColor = Theme.Danger
    elseif notifKind == "信息" then barColor = Theme.Accent end
    local notifRoot = CreateRoundFrame(NotificationContainer, UDim2.new(1, 0, 0, 0), UDim2.new(0, 0, 0, 0), Theme.NotificationBackground, UDim.new(0, 14))
    notifRoot.ZIndex = 201
    notifRoot.ClipsDescendants = true
    MakeStroke(notifRoot, barColor, 1.2)
    local sideBar = CreateRoundFrame(notifRoot, UDim2.new(0, 5, 1, 0), UDim2.new(0, 0, 0, 0), barColor, UDim.new(0, 14))
    sideBar.ZIndex = 202
    local sideBarFix = CreateFrame(notifRoot, UDim2.new(0, 5, 1, 0), UDim2.new(0, 5, 0, 0), barColor, 202)
    local kindLabel = CreateLabel(notifRoot, "【" .. notifKind .. "】 " .. title, UDim2.new(1, -20, 0, 20), UDim2.new(0, 16, 0, 10), barColor, Enum.Font.GothamBold, 14, Enum.TextXAlignment.Left, 203)
    local bodyLabel = CreateLabel(notifRoot, body, UDim2.new(1, -20, 0, 38), UDim2.new(0, 16, 0, 32), Theme.TextSecondary, Enum.Font.Gotham, 13, Enum.TextXAlignment.Left, 203)
    bodyLabel.TextWrapped = true
    local progressTrack = CreateRoundFrame(notifRoot, UDim2.new(1, -24, 0, 4), UDim2.new(0, 12, 1, -10), Theme.TertiaryBackground, UDim.new(1, 0))
    progressTrack.ZIndex = 202
    local progressFill = CreateRoundFrame(progressTrack, UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0), barColor, UDim.new(1, 0))
    progressFill.ZIndex = 203
    Tween(notifRoot, {Size = UDim2.new(1, 0, 0, 82)}, TweenSpring)
    task.spawn(function()
        local startTime = tick()
        while tick() - startTime < holdTime do
            local elapsed = tick() - startTime
            local remaining = 1 - (elapsed / holdTime)
            progressFill.Size = UDim2.new(remaining, 0, 1, 0)
            RunService.Heartbeat:Wait()
        end
    end)
    task.delay(holdTime, function()
        Tween(notifRoot, {Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1}, TweenMedium)
        task.wait(0.36)
        notifRoot:Destroy()
    end)
end
